From a52b98200c9f83a0945f2652b74650bf85a54e5b Mon Sep 17 00:00:00 2001
From: Garrett Brown <themagnificentmrb@gmail.com>
Date: Wed, 6 May 2026 21:09:30 -0700
Subject: [PATCH 3/3] Fix uae4arm AArch64 Pandora defines

Do not define PANDORA for AArch64 libretro builds.

The AArch64 build already avoids CPU_AARCH64 and ARMV6_ASSEMBLY, but
PANDORA still enables ARM32 optimized drawing code. That path emits
AArch32-only instructions such as pkhbt, which are invalid when building
for AArch64.

Keep PANDORA for non-AArch64 builds so the existing ARM32 behavior is
unchanged.
---
 Makefile.libretro | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/Makefile.libretro b/Makefile.libretro
index 61f7e27..057570f 100644
--- a/Makefile.libretro
+++ b/Makefile.libretro
@@ -211,10 +211,10 @@ else
 endif
 
 ifneq ($(AARCH64), 1)
-    DEFS += -DARMV6_ASSEMBLY
+    DEFS += -DARMV6_ASSEMBLY -DPANDORA
 endif
 
-DEFS += -DPANDORA -DRASPBERRY -DWITH_INGAME_WARNING
+DEFS += -DRASPBERRY -DWITH_INGAME_WARNING
 
 ifeq ($(USE_PICASSO96), 1)
 	DEFS += -DPICASSO96
